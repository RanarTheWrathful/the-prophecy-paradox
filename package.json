    "host": "node standaloneClient/index",
    "build": "node standaloneClient/build minify"
  },
  "dependencies": {
    "fluent-ffmpeg": "^2.1.3",
    "node-wav": "^0.0.2",
    "node-web-audio-api": "^0.21.1",
    "play-sound": "^1.1.6",
    "ws": "^8.13.0"
  },
  "engines": {
    "node": "16.x"
  },
